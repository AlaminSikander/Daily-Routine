# Supabase — Dashboard → Project Settings → API (use Project URL, not the dashboard link)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (optional advanced operations)
SUPABASE_SERVICE_ROLE_KEY=

# Python AI service (local: http://127.0.0.1:8000)
AI_SERVICE_URL=http://127.0.0.1:8000

# Optional: OpenAI for smarter parsing (FastAPI)
OPENAI_API_KEY=
